VERSION 16.0
POSITION . . 460 160

CANCEL can1, label("Close")
HELP   hlp1, view("help midas_condiplot")
RESET  res1
COPY   copy1

SUBMIT sub1, label("Submit")

DIALOG main, title("MIDAS -- Conditional Probability Plot")
BEGIN
    GROUPBOX gb_p  10  10 440  60, label("Plot options")
    CHECKBOX ck_trn  20  30 200 ., label("Truncated prevalence range") option(truncated)
END

PROGRAM command
BEGIN
    put "midas condiplot"
    beginoptions
        option main.ck_trn
    endoptions
END
