* ==============================================================================
* THESIS DIAGRAM GENERATOR - COMPLETE VERSION 6.2.0 FIXED CENTERING
* Author: Wu Lianghai, Anhui University of Technology (AHUT)
*         Ma'anshan, China, E-mail: agd2010@yeah.net
*         Wu Hanyan, School of Economics and Management,
*         Nanjing University of Aeronautics and Astronautics (NUAA)
*         Nanjing, China, E-mail: 2325476320@qq.com
*         Jin Xuening, Anhui University of Technology (AHUT)
*         Ma'anshan, China, E-mail: 1418924481@qq.com
* Version: 6.2.0 Fixed Centering and Positioning
* Date: 09Feb2026
* Description: Generate LaTeX code for thesis framework diagrams with 5 templates
* Supports Chinese and English languages
* ==============================================================================

capture program drop thesis_diagram
program define thesis_diagram
    version 16.0
    syntax , filename(string) [Template(integer 1) Title(string) Author(string) ///
                              University(string) Language(string) SIMple REPLACE]
    
    * --------------------------------------------------------------------------
    * PARAMETER VALIDATION AND DEFAULT SETTINGS
    * --------------------------------------------------------------------------
    if `template' < 1 | `template' > 5 {
        display as error "Template number must be between 1 and 5"
        exit 198
    }
    
    if missing("`filename'") {
        local filename "thesis_diagram.tex"
    }
    
    * Ensure .tex extension
    if !regexm("`filename'", "\.tex$") {
        local filename "`filename'.tex"
    }
    
    * Language setting (default: English)
    if missing("`language'") {
        local language "english"
    }
    else {
        local language = lower(substr("`language'", 1, 1))
        if "`language'" == "c" | "`language'" == "z" | "`language'" == "中" {
            local language "chinese"
        }
        else {
            local language "english"
        }
    }
    
    * Set default values based on language
    if missing("`title'") {
        if "`language'" == "chinese" {
            local title "博士学位论文研究框架"
        }
        else {
            local title "Doctoral Dissertation Research Framework"
        }
    }
    
    * Default author and university (empty by default)
    local show_author = !missing("`author'")
    local show_university = !missing("`university'")
    
    * --------------------------------------------------------------------------
    * CHECK IF FILE EXISTS AND REPLACE OPTION
    * --------------------------------------------------------------------------
    if "`replace'" != "" & "`replace'" != "r" {
        local replace "replace"
    }
    
    if "`replace'" == "" {
        capture confirm file "`filename'"
        if !_rc {
            display as error "File `filename' already exists. Use replace option to overwrite."
            exit 602
        }
    }
    
    * --------------------------------------------------------------------------
    * GENERATE LATEX FILE
    * --------------------------------------------------------------------------
    tempname fh
    file open `fh' using "`filename'", write text replace
    
    * Write LaTeX document header with proper centering
    file write `fh' "% ==============================================================================" _n
    file write `fh' "% THESIS FRAMEWORK DIAGRAM - FIXED CENTERING VERSION 6.2.0" _n
    file write `fh' "% Generated by thesis_diagram v6.2.0" _n
    file write `fh' "% Date: 09Feb2026" _n
    file write `fh' "% Authors: Wu Lianghai, Wu Hanyan, Jin Xuening" _n
    file write `fh' "% Language: `language'" _n
    file write `fh' "% Template: `template'" _n
    file write `fh' "% Note: Fixed all centering and left truncation issues" _n
    file write `fh' "% ==============================================================================" _n(2)
    
    if "`language'" == "chinese" {
        file write `fh' "\documentclass[border=5pt]{ctexart}" _n
    }
    else {
        file write `fh' "\documentclass[border=5pt]{standalone}" _n
    }
    
    file write `fh' "\usepackage{tikz}" _n
    file write `fh' "\usetikzlibrary{shapes.geometric, arrows.meta, positioning, calc, backgrounds}" _n
    file write `fh' "\usepackage{xcolor}" _n
    file write `fh' "\usepackage{amsmath}" _n
    file write `fh' "\usepackage{fontspec}" _n
    file write `fh' "\usepackage[paper=a4paper, margin=25mm]{geometry}" _n  // Increased margins to 25mm
    if "`language'" == "chinese" {
        file write `fh' "\usepackage[slantfont, boldfont]{xeCJK}" _n
    }
    file write `fh' "" _n
    
    file write `fh' "\begin{document}" _n
    file write `fh' "\centering" _n
    file write `fh' "\pagestyle{empty}" _n  // Remove page numbers
    file write `fh' "" _n
    
    * --------------------------------------------------------------------------
    * SELECT AND GENERATE TEMPLATE
    * --------------------------------------------------------------------------
    if `template' == 1 {
        template1_final `fh' "`title'" "`author'" "`university'" "`language'" "`show_author'" "`show_university'"
    }
    else if `template' == 2 {
        template2_final `fh' "`title'" "`author'" "`university'" "`language'" "`show_author'" "`show_university'" "`simple'"
    }
    else if `template' == 3 {
        template3_final `fh' "`title'" "`author'" "`university'" "`language'" "`show_author'" "`show_university'" "`simple'"
    }
    else if `template' == 4 {
        template4_final `fh' "`title'" "`author'" "`university'" "`language'" "`show_author'" "`show_university'"
    }
    else if `template' == 5 {
        template5_final `fh' "`title'" "`author'" "`university'" "`language'" "`show_author'" "`show_university'"
    }
    
    file write `fh' "\end{document}" _n
    
    file close `fh'
    
    * --------------------------------------------------------------------------
    * DISPLAY SUCCESS MESSAGE
    * --------------------------------------------------------------------------
    display as text _n "{hline 70}"
    display as text "{bf:SUCCESS: Thesis framework diagram generated!}" _n
    display as text "File saved to: {bf:`filename'}" _n
    display as text "Template: `template' | Language: `language'" _n
    if `template' == 3 {
        display as text "{bf:Note: Template 3 now has fixed centering}" _n
    }
    if `template' == 4 {
        display as text "{bf:Note: Template 4 now has fixed centering}" _n
    }
    display as text "{hline 35}" _n
    display as text "{bf:COMPILE COMMANDS:}" _n
    if "`language'" == "chinese" {
        display as text "1. {stata xelatex --interaction=nonstopmode `filename'}" _n
        display as text "2. {stata lualatex --interaction=nonstopmode `filename'}" _n
    }
    else {
        display as text "1. {stata pdflatex --interaction=nonstopmode `filename'}" _n
        display as text "2. {stata xelatex --interaction=nonstopmode `filename'}" _n
    }
    display as text "{hline 35}" _n
    display as text "Developed by: Wu Lianghai, Wu Hanyan, Jin Xuening" _n
    display as text "Contact: {browse mailto:agd2010@yeah.net:agd2010@yeah.net}" _n
    display as text "{hline 70}" _n
    
end

* ==============================================================================
* TEMPLATE 1: CLASSIC HIERARCHICAL STRUCTURE (FINAL VERSION)
* ==============================================================================
program define template1_final
    args fh title author university language show_author show_university
    
    file write `fh' "\begin{tikzpicture}[>=stealth, node distance=1.2cm, scale=0.8, transform shape]" _n(2)
    
    * Title section
    file write `fh' "    % Title section - CENTERED" _n
    file write `fh' "    \node[rectangle, text width=12cm, align=center, font=\Large\bfseries] (title) at (0,0) {" _n
    file write `fh' "        `title'" _n
    if `show_author' | `show_university' {
        file write `fh' "        \\[4pt]" _n
        if `show_author' & `show_university' {
            file write `fh' "        \normalsize `author' | `university'" _n
        }
        else if `show_author' {
            file write `fh' "        \normalsize `author'" _n
        }
        else if `show_university' {
            file write `fh' "        \normalsize `university'" _n
        }
    }
    file write `fh' "    };" _n(2)
    
    if "`language'" == "chinese" {
        * Chinese version
        file write `fh' "    % Main research topic" _n
        file write `fh' "    \node[rectangle, draw=blue, fill=blue!10, thick, rounded corners," _n
        file write `fh' "          text width=10cm, align=center, minimum height=1.2cm, below=1.2cm of title," _n
