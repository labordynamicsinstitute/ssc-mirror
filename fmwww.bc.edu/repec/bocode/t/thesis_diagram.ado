        file write `fh' "          text width=9cm, align=center, minimum height=1cm, below=of part4] (part5) {第五章: 结论与建议};" _n(2)
    }
    else {
        * English version - centered
        file write `fh' "    % Main research topic" _n
        file write `fh' "    \node[rectangle, draw=blue, fill=blue!10, thick, rounded corners," _n
        file write `fh' "          text width=10cm, align=center, minimum height=1.2cm, below=1.2cm of title," _n
        file write `fh' "          font=\large] (main) {Research Topic: Analytical Framework};" _n(2)
        
        file write `fh' "    % Research sections" _n
        file write `fh' "    \node[rectangle, draw=green, fill=green!10, rounded corners," _n
        file write `fh' "          text width=9cm, align=center, minimum height=1cm, below=of main] (part1) {Chapter 1: Introduction};" _n
        
        file write `fh' "    \node[rectangle, draw=green, fill=green!10, rounded corners," _n
        file write `fh' "          text width=9cm, align=center, minimum height=1cm, below=of part1] (part2) {Chapter 2: Literature Review};" _n
        
        file write `fh' "    \node[rectangle, draw=green, fill=green!10, rounded corners," _n
        file write `fh' "          text width=9cm, align=center, minimum height=1cm, below=of part2] (part3) {Chapter 3: Methodology};" _n
        
        file write `fh' "    \node[rectangle, draw=green, fill=green!10, rounded corners," _n
        file write `fh' "          text width=9cm, align=center, minimum height=1cm, below=of part3] (part4) {Chapter 4: Empirical Analysis};" _n
        
        file write `fh' "    \node[rectangle, draw=green, fill=green!10, rounded corners," _n
        file write `fh' "          text width=9cm, align=center, minimum height=1cm, below=of part4] (part5) {Chapter 5: Conclusion};" _n(2)
    }
    
    file write `fh' "    % Connection arrows" _n
    file write `fh' "    \draw[->, thick, blue] (main) -- (part1);" _n
    file write `fh' "    \draw[->, thick, blue] (part1) -- (part2);" _n
    file write `fh' "    \draw[->, thick, blue] (part2) -- (part3);" _n
    file write `fh' "    \draw[->, thick, blue] (part3) -- (part4);" _n
    file write `fh' "    \draw[->, thick, blue] (part4) -- (part5);" _n(2)
    
    * Optional methods sidebar
    if "`language'" == "chinese" {
        file write `fh' "    % Methods sidebar - ADJUSTED POSITION" _n
        file write `fh' "    \node[rectangle, draw=orange, fill=orange!10, thick, rounded corners," _n
        file write `fh' "          text width=3.5cm, align=left, minimum height=4.5cm, left=0.5cm of part3] (methods) {" _n
        file write `fh' "        \textbf{研究方法:}\\" _n
        file write `fh' "        - 定量分析\\" _n
        file write `fh' "        - 定性分析\\" _n
        file write `fh' "        - 混合方法" _n
        file write `fh' "    };" _n(2)
    }
    else {
        file write `fh' "    % Methods sidebar - ADJUSTED POSITION" _n
        file write `fh' "    \node[rectangle, draw=orange, fill=orange!10, thick, rounded corners," _n
        file write `fh' "          text width=3.5cm, align=left, minimum height=4.5cm, right=0.5cm of part3] (methods) {" _n
        file write `fh' "        \textbf{Methods:}\\" _n
        file write `fh' "        - Quantitative\\" _n
        file write `fh' "        - Qualitative\\" _n
        file write `fh' "        - Mixed" _n
        file write `fh' "    };" _n(2)
