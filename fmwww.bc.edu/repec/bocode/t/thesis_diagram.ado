        file write `fh' "          text width=9cm, align=center, minimum height=1cm, below=of part2] (part3) {第三章: 研究方法};" _n
        
        file write `fh' "    \node[rectangle, draw=green, fill=green!10, rounded corners," _n
        file write `fh' "          text width=9cm, align=center, minimum height=1cm, below=of part3] (part4) {第四章: 实证分析};" _n
        
