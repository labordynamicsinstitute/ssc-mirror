    file write `fh' "    \draw[->, dashed, orange, thick] (part3) -- (methods);" _n
    file write `fh' "    \draw[->, dashed, orange, thick] (methods) -- (part4);" _n(2)
    
    * Figure caption
    file write `fh' "    % Figure caption - CENTERED" _n
    file write `fh' "    \node[below=0.8cm of part5, text width=12cm, align=center, font=\small\bfseries] (caption) at (0,-7) {" _n
    if "`language'" == "chinese" {
        file write `fh' "        图1: 研究框架图" _n
    }
    else {
        file write `fh' "        Figure 1: Research Framework Diagram" _n
    }
    file write `fh' "    };" _n(2)
    
    file write `fh' "\end{tikzpicture}" _n
    
end

