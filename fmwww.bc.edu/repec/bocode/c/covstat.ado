*! covstat 1.0.0  23jul2026   (flexur library)
*! Jansson-RALS covariate stationarity test: more powerful stationarity tests
*! with non-normal errors (RALS terms used as stationary covariates).
*!
*! Author : Dr Merwan Roudane  merwanroudane920@gmail.com
*!          https://github.com/merwanroudane
*! Part of the -flexur- library : flexible unit-root & stationarity tests.
*!
*! Faithful port of the GAUSS routine appl_JanssonRALS.gss by
*!   Saban Nazlioglu, Junsoo Lee, Cagin Karul & Yu You.  Non-commercial use.
*!
*! References:
*!   Nazlioglu, S., Lee, J., Karul, C., You, Y. (2021). Testing for stationarity
*!     with covariates: more powerful tests with non-normal errors. Studies in
*!     Nonlinear Dynamics & Econometrics. <doi:10.1515/snde-2019-0038>
*!   Jansson, M. (2004). Stationarity testing with covariates. Econometric
*!     Theory 20: 56-94.
*!   Im, K.S., Schmidt, P. (2008). More efficient estimation under non-normality:
*!     residuals augmented least squares. Journal of Econometrics 144: 219-233.
*!
*! Step -> equation map (see -help covstat methods-):
*!   RALS terms w = [e^2-m2, e^3-m3-3 m2 e]  (eq.3)   -> _jr_getrals
*!   Jansson Ly_T,Qy_T (benchmark) / L_T,Q_T (RALS)   -> _jr_jansson
*!   VAR(1)-prewhitened long-run covariance, QS kernel -> _jr_jansson (prewhite)
*!   signal-to-noise ratio rho2 = 1-omega_yy.x/omega_yy -> _jr_jansson
*!   response-surface p-values (Table 1 / 999 levels)  -> _jr_rspval

program covstat, rclass
    version 14.0

    syntax varname(numeric ts) [if] [in] [ ,   ///
        MODel(string)                           ///
        IID                                     ///
        Kernel(string)                          ///
        Graph                                   ///
        GNAME(string)                           ///
        GRAPHopts(string asis)                  ///
    ]

    marksample touse
    _jr_check_tsset
    local tvar `s(tvar)'

    quietly count if `touse'
    local T = r(N)
    if `T' < 20 {
        di as error "covstat: need at least 20 usable observations (found `T')."
        exit 2001
    }

    * deterministic model: 0 = constant, 1 = constant + trend
    if "`model'" == "" local model "trend"
    local model = lower("`model'")
    if      inlist("`model'","c","const","constant","level")  local p 0
    else if inlist("`model'","t","trend","ct")                local p 1
    else {
        di as error "covstat: model() must be constant or trend."
        exit 198
    }

    * pre-whitening (default) vs iid long-run variance
    local pw = 1
    if "`iid'" != "" local pw = 0

    tempname R
    mata: _jr_run("`varlist'", "`touse'", `p', `pw')
    matrix `R' = r(cs)

    * ----- display -----------------------------------------------------------
    local mdesc = cond(`p'==0,"Constant","Constant and trend")
    local lrdesc = cond(`pw'==1,"VAR(1)-prewhitened, QS kernel","i.i.d.")
    di ""
    di as text "Jansson-RALS covariate stationarity test"
    di as text "Nazlioglu, Lee, Karul & You (2021, SNDE)"
    di as text "{hline 68}"
    di as text "Series" _col(12) ": " as result "`varlist'" ///
        as text _col(44) "Obs (T)" _col(54) "= " as result %6.0f `T'
    di as text "Model" _col(12) ": " as result "`mdesc'" ///
        as text _col(44) "Long-run" _col(54) "= " as result "`lrdesc'"
    di as text "H0: series is stationary   (reject for large statistics / small p)"
    di as text "{hline 68}"
    di as text "  Test" _col(20) "Statistic" _col(34) "p-value" _col(46) "Note"
    di as text "{hline 68}"
    di as text "  {bf:Benchmark (no covariates)}"
    _jr_row "Ly_T (= KPSS)" `R'[1,1] `R'[2,1]
    _jr_row "Qy_T"          `R'[3,1] `R'[4,1]
    di as text "  {bf:Jansson-RALS (with RALS covariates)}"
    _jr_row "L_T"           `R'[5,1] `R'[6,1]
    _jr_row "Q_T"           `R'[7,1] `R'[8,1]
    di as text "{hline 68}"
    di as text "  Signal-to-noise ratio  rho^2 " _col(34) "= " as result %7.4f `R'[9,1]
    di as text "{hline 68}"
    di as text "Note: *** p<.01, ** p<.05, * p<.10 reject stationarity."
    di as text "      rho^2 near 0 => RALS covariates add little (Ly_T ~ KPSS)."

    * ----- returns -----------------------------------------------------------
    return scalar Ly_T   = `R'[1,1]
    return scalar Ly_p   = `R'[2,1]
    return scalar Qy_T   = `R'[3,1]
    return scalar Qy_p   = `R'[4,1]
    return scalar L_T    = `R'[5,1]
    return scalar L_p    = `R'[6,1]
    return scalar Q_T    = `R'[7,1]
    return scalar Q_p    = `R'[8,1]
    return scalar rho2   = `R'[9,1]
    return scalar T      = `T'
    return local  model  "`mdesc'"
    return local  cmd    "covstat"

    * ----- plot --------------------------------------------------------------
    if "`graph'" != "" {
        _jr_plot `varlist' if `touse', tvar(`tvar') p(`p') pw(`pw') ///
            gname(`gname') `graphopts'
    }
end


program _jr_check_tsset, sclass
    sreturn clear
    capture tsset
    if _rc == 0 sreturn local tvar "`r(timevar)'"
end


* small helper to print one result row with stars
program _jr_row
    args label stat pval
    local star = cond(`pval'<0.01,"***",cond(`pval'<0.05,"**",cond(`pval'<0.10,"*","")))
    di as text "  " %-16s "`label'" as result _col(20) %9.4f `stat' ///
        _col(34) %7.4f `pval' as result _col(46) "`star'"
end


* -------------------------------------------------------------------------
* plot: signal-to-noise diagnostic -- statistic vs its rho^2 critical curve
* -------------------------------------------------------------------------
program _jr_plot
    syntax varname [if] [in], P(integer) PW(integer) ///
        [ TVAR(string) GNAME(string) * ]
    marksample touse
    tempname R
    quietly mata: _jr_run("`varlist'", "`touse'", `p', `pw')
    matrix `R' = r(cs)
    local LT = `R'[5,1]
    local QT = `R'[7,1]
    local rho2 = `R'[9,1]

    preserve
    quietly clear
    quietly set obs 91
    tempvar rr cvL cvQ
    quietly gen double `rr' = (_n-1)/100
    quietly gen double `cvL' = .
    quietly gen double `cvQ' = .
    * 5% critical curve as a function of rho^2 (Table 1 response surface)
    local Lc0 = cond(`p'==0, 0.464, 0.149)
    local Lc1 = cond(`p'==0, 0.184, -0.006)
    local Lc2 = cond(`p'==0, 0.359, 0.042)
    local Lc3 = cond(`p'==0, 0.041, 0.003)
    local Lc4 = cond(`p'==0, -0.005, 0.000)
    local Qc0 = cond(`p'==0, -1.017, -4.021)
    local Qc1 = cond(`p'==0, 1.695, 1.575)
    local Qc2 = cond(`p'==0, -2.210, -3.976)
    local Qc3 = cond(`p'==0, -0.013, -0.194)
    local Qc4 = cond(`p'==0, 0.006, 0.029)
    quietly replace `cvL' = `Lc0' + `Lc1'*(`rr'/sqrt(1-`rr'^2)) + `Lc2'*(`rr'/sqrt(1-`rr'^2))^2 + `Lc3'*(`rr'/sqrt(1-`rr'^2))^3 + `Lc4'*(`rr'/sqrt(1-`rr'^2))^4
    quietly replace `cvQ' = `Qc0' + `Qc1'*(`rr'/sqrt(1-`rr'^2)) + `Qc2'*(`rr'/sqrt(1-`rr'^2))^2 + `Qc3'*(`rr'/sqrt(1-`rr'^2))^3 + `Qc4'*(`rr'/sqrt(1-`rr'^2))^4

    local gn ""
    if "`gname'" != "" local gn name(`gname', replace)
    twoway (line `cvL' `rr', lcolor(navy) lwidth(medthick))                    ///
           (line `cvQ' `rr', lcolor(forest_green) lwidth(medthick) lpattern(dash)) , ///
        yline(`LT', lcolor(navy) lpattern(shortdash))                          ///
        yline(`QT', lcolor(forest_green) lpattern(shortdash))                  ///
        xline(`rho2', lcolor(cranberry) lpattern(dot))                         ///
        legend(order(1 "L_T 5% CV" 2 "Q_T 5% CV") rows(1))                     ///
        xtitle("signal-to-noise ratio {&rho}{sup:2}")                          ///
        ytitle("statistic / 5% critical value")                               ///
        title("Jansson-RALS: statistic vs {&rho}{sup:2} critical curve")       ///
        graphregion(color(white)) plotregion(color(white)) `gn' `options'
    restore
end


* =========================================================================
* Mata engine
* =========================================================================
version 14.0
mata:

// ---- OLS residuals of y on X ------------------------------------------
real matrix _jr_resid(real matrix y, real matrix X)
{
    return(y - X*qrsolve(X, y))
}

// ---- RALS terms w = [e^2-m2 , e^3-m3-3 m2 e] --------------------------
real matrix _jr_getrals(real colvector y, real scalar p, real scalar T)
{
    real matrix X
    real colvector e, e2, e3, w1, w2
    real scalar m2, m3
    if (p == 0) X = J(T,1,1)
    else        X = J(T,1,1) , (1::T)
    e  = _jr_resid(y, X)
    e2 = e :* e
    e3 = e2 :* e
    m2 = mean(e2)
    m3 = mean(e3)
    w1 = e2 :- m2
    w2 = e3 :- m3 :- 3*m2*e
    return(w1 , w2)
}

// ---- Jansson statistics ; returns (Ly_T,Qy_T,L_T,Q_T,rho2hat) ---------
real rowvector _jr_jansson(real colvector Y, real matrix X, real scalar p, real scalar prewhite)
{
    real scalar T, k, lambdabar, c_lbar, OMEGAyy, OMEGAyy_x, GAMMAyy, GAMMAyy_x
    real scalar Ly_T, Qy_T, Py_T, P_T, Q_T, L_T, L_Tstar, L_T2star, rho2hat, s2, ii, j, t
    real colvector Vyhat, Sy, diffY, Y_lbar, OMEGAxy_xx, betatildey
    real colvector Sum_Vytilde, Vytilde, S_Dz, S_Dz_yy, S_Dz_yx, S_Dz_xy, S_Dz_xx, S_Dv
    real matrix Dy, Dx, Vxhat, Vhat, SIGMAhat, OMEGAhat, GAMMAhat, invOMEGA, invOMEGAxx
    real matrix Dy_lbar, diffDy, S_DD, S_DD_yy, S_DD_xy, S_DD_xx
    real matrix S_DD_lbar, S_DD_yy_lbar, S_DD_xy_lbar, S_Dz_lbar, S_Dz_yy_lbar
    real matrix S_Dz_yx_lbar, S_Dz_xy_lbar, betatilde, betatildex, Vxtilde, Vtilde
    real matrix Sum_Vtilde, Sum_Vxtilde, YX, YlX
    real scalar invOMEGAyy, S_zz, S_zz_D, S_zz_lbar, S_zz_D_lbar
    real colvector invOMEGAxy
    // prewhitening locals
    real matrix vb, vf, A_OLS, Bmat, D_OLS2, A, Vhat_pw
    real matrix SIGMAhat_pw, SIGMAhat1_star, GAMMAhat_pw, OMEGAhat_pw, IA
    transmorphic V_OLS, D_OLS1, D, D_OLS
    real rowvector input, weights
    real colvector ARcoeff, ARvar, resid
    real scalar s, ahat, shat, ahat_num, ahat_den, max_VAR, min_ahat, max_ahat

    T = rows(Y)
    k = cols(X)
    if (p == 0) {
        Dy = J(T,1,1)
        Dx = J(T,1,1)
    }
    else {
        Dy = J(T,1,1) , (1::T)
        Dx = Dy
    }
    Vyhat = _jr_resid(Y, Dy)
    Vxhat = _jr_resid(X, Dx)
    Vhat  = Vyhat , Vxhat
    SIGMAhat = cross(Vhat, Vhat) / T

    if (prewhite == 0) {
        OMEGAhat = SIGMAhat
        OMEGAyy   = OMEGAhat[1,1]
        OMEGAxy_xx = luinv(OMEGAhat[2..k+1,2..k+1]) * OMEGAhat[2..k+1,1]
        OMEGAyy_x = OMEGAhat[1,1] - OMEGAxy_xx' * OMEGAhat[2..k+1,1]
        GAMMAyy   = 0
        GAMMAyy_x = 0
    }
    else {
        max_VAR = 0.97
        min_ahat = 0.05
        max_ahat = 5
        vb = Vhat[1..T-1,.]
        vf = Vhat[2..T,.]
        Bmat = invsym(cross(vb,vb)) * cross(vb,vf)
        A_OLS = Bmat'
        eigensystem(A_OLS, V_OLS=., D_OLS=.)
        D_OLS1 = diag(D_OLS)
        D_OLS2 = abs(D_OLS1 :/ max_VAR)
        for (ii=1; ii<=k+1; ii++) {
            if (D_OLS2[ii,ii] < 1) D_OLS2[ii,ii] = 1
        }
        D = D_OLS1 * luinv(D_OLS2)
        A = Re(V_OLS * D * luinv(V_OLS))
        Vhat_pw = vf - vb*A'
        s = 1.3221 * (T^(1/5))
        ARcoeff = J(k+1,1,0)
        ARvar   = J(k+1,1,0)
        for (j=1; j<=k+1; j++) {
            ARcoeff[j] = cross(Vhat_pw[1..T-2,j], Vhat_pw[2..T-1,j]) / cross(Vhat_pw[1..T-2,j], Vhat_pw[1..T-2,j])
            resid = Vhat_pw[2..T-1,j] - ARcoeff[j]*Vhat_pw[1..T-2,j]
            ARvar[j] = cross(resid,resid) / (T-2)
        }
        ahat_num = 4 * sum((ARcoeff:^2 :* ARvar:^2) :/ ((1 :- ARcoeff):^8))
        ahat_den = sum((ARvar:^2) :/ ((1 :- ARcoeff):^4))
        ahat = (ahat_num/ahat_den)^(1/5)
        if (ahat > max_ahat) ahat = max_ahat
        if (ahat < min_ahat) ahat = min_ahat
        shat = ahat * s
        SIGMAhat_pw = cross(Vhat_pw,Vhat_pw) / (T-1)
        SIGMAhat1_star = cross(Vhat_pw, Vhat[1..T-1,.]) / (T-1)
        input = (6*pi()*((1..T-2) :/ shat)) / 5
        weights = (3 :/ (input:^2)) :* (sin(input):/input :- cos(input))
        GAMMAhat_pw = J(k+1,k+1,0)
        for (j=1; j<=T-2; j++) {
            GAMMAhat_pw = GAMMAhat_pw + weights[j] * (cross(Vhat_pw[j+1..T-1,.], Vhat_pw[1..T-j-1,.]) / (T-1))
        }
        OMEGAhat_pw = GAMMAhat_pw + GAMMAhat_pw' + SIGMAhat_pw
        IA = I(k+1) - A
        OMEGAhat = luinv(IA) * OMEGAhat_pw * luinv(IA)'
        GAMMAhat = luinv(IA)*GAMMAhat_pw*luinv(IA)' + luinv(IA)*A*SIGMAhat - luinv(IA)*SIGMAhat1_star*A'*luinv(IA)'
        OMEGAyy   = OMEGAhat[1,1]
        OMEGAxy_xx = luinv(OMEGAhat[2..k+1,2..k+1]) * OMEGAhat[2..k+1,1]
        OMEGAyy_x = OMEGAhat[1,1] - OMEGAxy_xx' * OMEGAhat[2..k+1,1]
        GAMMAyy   = GAMMAhat[1,1]
        GAMMAyy_x = GAMMAhat[1,1] - OMEGAxy_xx' * GAMMAhat[2..k+1,1]
    }

    // GLS-transformed data
    if (p == 0) {
        lambdabar = 7.00
        diffDy = J(T,1,0)
    }
    else {
        lambdabar = 12.00
        diffDy = J(T,1,0) , J(T,1,1)
    }
    c_lbar = 1 - lambdabar/T
    Dy_lbar = J(T,p+1,0)
    Y_lbar  = J(T,1,0)
    Dy_lbar[1,.] = Dy[1,.]
    Y_lbar[1] = Y[1]
    diffY = J(T,1,0)
    diffY[2..T] = Y[2..T] - Y[1..T-1]
    for (t=2; t<=T; t++) {
        Dy_lbar[t,.] = c_lbar :* Dy_lbar[t-1,.] + diffDy[t,.]
        Y_lbar[t]    = c_lbar * Y_lbar[t-1] + diffY[t]
    }

    // benchmark (univariate) tests
    Sy = runningsum(Vyhat) / T
    Ly_T = cross(Sy,Sy) / OMEGAyy
    Py_T = ( (cross(Y,Y) - cross(Y,Dy)*qrsolve(cross(Dy,Dy), cross(Dy,Y))) ///
           - (cross(Y_lbar,Y_lbar) - cross(Y_lbar,Dy_lbar)*qrsolve(cross(Dy_lbar,Dy_lbar), cross(Dy_lbar,Y_lbar))) ) / OMEGAyy
    Qy_T = Py_T - 2*lambdabar*GAMMAyy/OMEGAyy

    // covariate tests
    invOMEGA   = luinv(OMEGAhat)
    invOMEGAyy = invOMEGA[1,1]
    invOMEGAxy = invOMEGA[2..k+1,1]
    invOMEGAxx = invOMEGA[2..k+1,2..k+1]

    YX = Y , X
    S_zz = trace(invOMEGA * cross(YX,YX))
    S_DD_yy = invOMEGAyy * cross(Dy,Dy)
    S_DD_xy = invOMEGAxy # cross(Dx,Dy)
    S_DD_xx = invOMEGAxx # cross(Dx,Dx)
    S_DD    = (S_DD_yy , S_DD_xy') \ (S_DD_xy , S_DD_xx)
    S_Dz_yy = cross(Dy,Y) * invOMEGAyy
    S_Dz_yx = cross(Dy,X) * invOMEGAxy
    S_Dz_xy = invOMEGAxy # cross(Dx,Y)
    S_Dz_xx = rowshape((cross(Dx,X)*invOMEGAxx)', k*(p+1))
    S_Dz    = (S_Dz_yy + S_Dz_yx) \ (S_Dz_xy + S_Dz_xx)
    S_zz_D  = S_zz - S_Dz' * luinv(S_DD)' * S_Dz

    YlX = Y_lbar , X
    S_zz_lbar = trace(invOMEGA * cross(YlX,YlX))
    S_DD_yy_lbar = invOMEGAyy * cross(Dy_lbar,Dy_lbar)
    S_DD_xy_lbar = invOMEGAxy # cross(Dx,Dy_lbar)
    S_DD_lbar    = (S_DD_yy_lbar , S_DD_xy_lbar') \ (S_DD_xy_lbar , S_DD_xx)
    S_Dz_yy_lbar = cross(Dy_lbar,Y_lbar) * invOMEGAyy
    S_Dz_yx_lbar = cross(Dy_lbar,X) * invOMEGAxy
    S_Dz_xy_lbar = invOMEGAxy # cross(Dx,Y_lbar)
    S_Dz_lbar    = (S_Dz_yy_lbar + S_Dz_yx_lbar) \ (S_Dz_xy_lbar + S_Dz_xx)
    S_zz_D_lbar  = S_zz_lbar - S_Dz_lbar' * luinv(S_DD_lbar)' * S_Dz_lbar

    P_T = S_zz_D - S_zz_D_lbar
    Q_T = P_T - 2*lambdabar*GAMMAyy_x/OMEGAyy_x

    betatilde  = luinv(S_DD)' * S_Dz
    betatildey = betatilde[1..p+1]
    betatildex = rowshape(betatilde[(p+2)..(p+1+k*(p+1))], k)'
    Vytilde = Y - Dy*betatildey
    Vxtilde = X - Dx*betatildex
    Vtilde  = Vytilde , Vxtilde
    Sum_Vtilde = _jr_cumsum(Vtilde) / T
    Sum_Vytilde = Sum_Vtilde[.,1]
    Sum_Vxtilde = Sum_Vtilde[.,2..k+1]
    L_Tstar = (cross(Sum_Vytilde,Sum_Vytilde) - 2*Sum_Vytilde'*Sum_Vxtilde*OMEGAxy_xx) / OMEGAyy_x
    S_Dv = ( (-cross(Dy,Sum_Vxtilde)) \ (I(k) # cross(Dx,Sum_Vytilde)) ) * (OMEGAxy_xx / OMEGAyy_x)
    L_T2star = S_Dv' * luinv(S_DD) * S_Dv
    L_T = L_Tstar + L_T2star
    rho2hat = 1 - OMEGAyy_x/OMEGAhat[1,1]

    return((Ly_T, Qy_T, L_T, Q_T, rho2hat))
}

// ---- column-wise cumulative sums --------------------------------------
real matrix _jr_cumsum(real matrix X)
{
    real matrix S
    real scalar j
    S = X
    for (j=1; j<=cols(X); j++) S[.,j] = runningsum(X[.,j])
    return(S)
}

// ---- select embedded 999x5 parameter block for (model,test) -----------
real matrix _jr_cvparams(real scalar model, real scalar test)
{
    if (model == 0 & test == 1) return(_jr_p0t1())
    if (model == 1 & test == 1) return(_jr_p1t1())
    if (model == 0 & test == 2) return(_jr_p0t2())
    return(_jr_p1t2())
}

// ---- response-surface p-value (MacKinnon interpolation) ---------------
real scalar _jr_rspval(real scalar stat, real scalar rho2in, real scalar model, real scalar test)
{
    real matrix params, obs, Xw
    real colvector sig, qcv, yv, bw, idx
    real rowvector reg
    real scalar rho2, z, bands, lower, pval, mn, mx, lo, hi

    rho2 = rho2in
    if (rho2 > 0.9) rho2 = 0.9
    if (rho2 < 0) rho2 = 0
    z = rho2 / sqrt(1 - rho2^2)
    reg = (1, z, z^2, z^3, z^4)

    params = _jr_cvparams(model, test)
    sig = (1::999) / 1000
    qcv = params[,1]*reg[1] + params[,2]*reg[2] + params[,3]*reg[3] + params[,4]*reg[4] + params[,5]*reg[5]

    mn = min(qcv)
    mx = max(qcv)
    bands = 11
    if (stat <= mn) return(1)
    if (stat >= mx) return(0.0001)

    // largest index with qcv <= stat
    idx = selectindex(qcv :<= stat)
    lower = max(idx)
    lo = lower - bands + 1
    hi = lower + bands
    if (lower < bands) {
        lo = 1
        hi = 2*bands
    }
    if (lower > rows(qcv)-bands) {
        lo = rows(qcv) - 2*bands + 1
        hi = rows(qcv)
    }
    obs = (sig[lo..hi] , qcv[lo..hi])
    yv = invnormal(obs[,1])
    Xw = J(rows(obs),1,1) , obs[,2] , obs[,2]:^2 , obs[,2]:^3
    bw = qrsolve(Xw, yv)
    pval = 1 - normal((1, stat, stat^2, stat^3) * bw)
    if (pval > 1) pval = 1
    if (pval < 0) pval = 0.0001
    return(pval)
}

// ---- driver : compute, p-value, post r(cs) -------------------------
void _jr_run(string scalar vname, string scalar touse, real scalar p, real scalar prewhite)
{
    real colvector y
    real matrix w, out
    real rowvector J6
    real scalar Ly, Qy, L, Q, rho2, model, Ly_p, Qy_p, L_p, Q_p

    y = st_data(., vname, touse)
    w = _jr_getrals(y, p, rows(y))
    J6 = _jr_jansson(y, w, p, prewhite)
    Ly = J6[1]; Qy = J6[2]; L = J6[3]; Q = J6[4]; rho2 = J6[5]

    model = p
    // benchmark tests: rho2 = 0 (KPSS / Jansson without covariates)
    Ly_p = _jr_rspval(Ly, 0, model, 1)
    Qy_p = _jr_rspval(Qy, 0, model, 2)
    L_p  = _jr_rspval(L,  rho2, model, 1)
    Q_p  = _jr_rspval(Q,  rho2, model, 2)

