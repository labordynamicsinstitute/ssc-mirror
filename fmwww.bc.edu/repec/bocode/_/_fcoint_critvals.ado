  * Parse into tokens
  tokenize `cvstr'
  
  * Interpolate based on T
  if `T' <= 100 {
    local cv1  = `1'
    local cv5  = `2'
    local cv10 = `3'
  }
  else if `T' <= 500 {
    * Linear interpolation between T=100 and T=500
    local w = (`T' - 100) / 400
    local cv1  = `1' + `w' * (`4' - `1')
