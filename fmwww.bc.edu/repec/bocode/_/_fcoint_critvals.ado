*! _fcoint_critvals.ado -- Critical value lookup for fcoint package
*! Sources:
*!   Banerjee, Arcabic & Lee (2017, Econ. Modelling) -- Tables 1a,1b,2a,2b
*!   Banerjee & Lee (working paper) -- Tables 1a-1d, 2a-2d
*!   Tsong, Lee, Tsai & Hu (2016, Empir. Econ.) -- Table 1
*! Author: Dr Merwan Roudane (merwanroudane920@gmail.com)
*! Version 1.0.0

* =====================================================================
* FADL critical values -- Banerjee et al. (2017)
* Returns r(cv1), r(cv5), r(cv10)
* =====================================================================

program define _fcoint_cv_fadl, rclass
  syntax, n(integer) k(integer) T(integer) model(string) [cumfreq]
  
  * Select table based on model and cumfreq
  * model = "constant" => Table 1a / 2a
  * model = "trend"    => Table 1b / 2b
  
  if "`cumfreq'" != "" {
    * Cumulative frequency tables (q = k here)
    _fcoint_cv_fadl_cumul, n(`n') q(`k') T(`T') model(`model')
  }
  else {
    * Single frequency tables
    _fcoint_cv_fadl_single, n(`n') k(`k') T(`T') model(`model')
  }
  
  return scalar cv1  = r(cv1)
  return scalar cv5  = r(cv5)
  return scalar cv10 = r(cv10)
end

* ---------------------------------------------------------------------
* FADL single frequency: Tables 1a (constant) and 1b (trend)
* Indexed by n (1-3), k (1-5), T (100,500,2500)
* We interpolate between T values
* ---------------------------------------------------------------------

