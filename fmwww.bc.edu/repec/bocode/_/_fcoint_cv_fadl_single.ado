  local c_1_5_1 "-4.00 -3.32 -2.97 -3.94 -3.32 -2.99 -3.96 -3.32 -3.00"
  local c_2_1_1 "-4.96 -4.32 -3.98 -4.85 -4.26 -3.95 -4.81 -4.25 -3.95"
  local c_2_2_1 "-4.79 -4.10 -3.73 -4.66 -4.03 -3.70 -4.64 -4.03 -3.70"
