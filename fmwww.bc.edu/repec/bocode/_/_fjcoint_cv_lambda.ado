        15.86571, 24.05796, 30.45904, 37.58944, 43.98831 \ ///
        14.21382, 22.17946, 29.61400, 36.66324, 42.69462 \ ///
        13.22626, 20.99576, 28.10436, 35.01388, 41.95523 \ ///
