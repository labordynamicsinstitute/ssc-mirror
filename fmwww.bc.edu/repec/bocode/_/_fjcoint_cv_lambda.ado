    else if `model' == 2 {
      matrix `cv_fl' = ( ///
        18.09039, 25.46954, 32.22024, 38.25462, 44.55845 \ ///
        24.65593, 32.06307, 38.79872, 45.22149, 52.11245 \ ///
        30.28825, 38.46600, 45.62627, 52.60794, 59.17533 \ ///
        36.91493, 44.75700, 52.37514, 59.21325, 65.76993 \ ///
