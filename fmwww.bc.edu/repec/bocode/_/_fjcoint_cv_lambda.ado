        18.90748, 26.44461, 33.03344, 39.23833, 45.38248 \ ///
        16.37934, 24.68322, 30.95725, 38.17910, 44.72682 \ ///
        14.82827, 22.90663, 30.23652, 37.29780, 43.44843 \ ///
