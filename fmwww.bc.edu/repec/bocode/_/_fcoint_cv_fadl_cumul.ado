*! _fcoint_cv_fadl_cumul.ado -- FADL cumulative frequency critical values
*! Banerjee et al. (2017) Tables 2a, 2b
program define _fcoint_cv_fadl_cumul, rclass
  syntax, n(integer) q(integer) tobs(integer) model(string)
  if `n' < 1 local n = 1
  if `n' > 3 local n = 3
  if `q' < 1 local q = 1
  if `q' > 5 local q = 5
  * Table 2a: Constant
  local q_1_1_1 "-4.73 -4.09 -3.76 -4.61 -4.03 -3.72 -4.60 -4.02 -3.72"
  local q_1_2_1 "-5.40 -4.76 -4.43 -5.24 -4.68 -4.37 -5.23 -4.67 -4.37"
