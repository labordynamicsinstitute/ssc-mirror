    local cvstr = "`f2_`n'_`k'_`rho_idx'_1'"
  }
  tokenize `cvstr'
  if `tobs' <= 100 {
    local cv1  = `1'
    local cv5  = `2'
    local cv10 = `3'
  }
  else {
    local cv1  = `4'
    local cv5  = `5'
