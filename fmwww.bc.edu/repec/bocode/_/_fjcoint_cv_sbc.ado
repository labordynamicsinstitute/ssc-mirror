          43.925, 84.642, 127.695, 174.955, 225.235, 280.043, 339.052, 403.589 )
      }
    }
    
    return scalar cv = `cv_ft'[`f', `n_r']
    return matrix cv_matrix = `cv_ft'
    exit
  }
  
end
